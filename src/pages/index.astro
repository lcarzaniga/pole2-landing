---
import Base from '../layouts/Base.astro';
import Wordmark from '../components/Wordmark.astro';
import Kobe from '../components/Kobe.astro';
import HexTexture from '../components/HexTexture.astro';
import WaitlistForm from '../components/WaitlistForm.astro';

const steps = [
  { title: 'Conserva', body: 'Affidi a Pole² una cosa a cui tieni. In un momento è al sicuro.' },
  { title: 'Respira', body: 'Non devi più tenere tutto a mente. Ci pensa lui.' },
  { title: 'Ritrova', body: 'Quando servirà, sarà lì. Al suo posto, come l’avevi lasciato.' },
];

const privacy = ['Niente cloud.', 'Niente account.', 'Niente abbonamento.'];
---

<Base>
  <!-- ============================= HERO ============================= -->
  <header class="hero">
    <HexTexture color="#f6f1e7" opacity={0.05} cell={58} />
    <div class="wrap hero__grid">
      <div class="hero__text">
        <Wordmark as="h1" size="clamp(3.2rem, 2rem + 9vw, 6rem)" class="hero__mark" />
        <p class="hero__tagline">
          Custodisci ciò che conta.<br />Conta ciò che custodisci.
        </p>
        <p class="hero__sentence">
          La pace di sapere dov’è ciò a cui tieni.
        </p>
        <div class="hero__cta">
          <a class="btn btn--onPetrol" href="#lista">Tienimi un posto</a>
          <p class="hero__reassure">Resta tutto sul tuo dispositivo.</p>
        </div>
      </div>
      <div class="hero__turtle">
        <Kobe size="min(72vw, 320px)" halo />
      </div>
    </div>
  </header>

  <main id="contenuto">
    <!-- ========================== NARRATIVE ========================== -->
    <section class="section narrative" aria-labelledby="story-h">
      <div class="wrap read">
        <p class="anxiety reveal" id="story-h">«So di averlo.<br />Ma dov’è?»</p>
        <div class="narrative__body reveal">
          <p>
            Le cose non diventano un problema quando le perdiamo. Lo diventano
            mesi dopo, quando ci serve ciò che le accompagnava — e non lo
            troviamo.
          </p>
          <p class="narrative__refrain">
            La ricevuta. La garanzia. Il manuale.<br />
            Quell’appunto che ci eravamo ripromessi di ricordare.
          </p>
          <p>Pole² tiene tutto vicino, così domani non è mai più difficile di oggi.</p>
        </div>
      </div>
    </section>

    <!-- ========================= HOW IT FEELS ========================= -->
    <section class="section section--alt" aria-labelledby="how-h">
      <div class="wrap">
        <div class="read reveal">
          <p class="eyebrow">Come ci si sente</p>
          <h2 id="how-h">Affidare. E lasciar andare.</h2>
        </div>
        <ul class="steps" role="list">
          {
            steps.map((s) => (
              <li class="steps__item reveal">
                <span class="steps__mark" aria-hidden="true" />
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <!-- ============================ PRIVACY ============================ -->
    <section class="section privacy" aria-labelledby="privacy-h">
      <HexTexture color="#f6f1e7" opacity={0.045} cell={58} />
      <div class="wrap read reveal privacy__inner">
        <p class="eyebrow eyebrow--onPetrol">Privacy</p>
        <h2 id="privacy-h">Le tue cose restano tue.</h2>
        <p class="privacy__lead">Pole² funziona senza chiederti nulla.</p>
        <ul class="privacy__list">
          {privacy.map((p) => <li>{p}</li>)}
        </ul>
        <p class="privacy__closing">
          I tuoi dati vivono sul tuo dispositivo. Se un giorno vorrai
          condividerli, deciderai tu — sempre.
        </p>
      </div>
    </section>

    <!-- ========================= BRAND STORY ========================= -->
    <section class="section" aria-labelledby="name-h">
      <div class="wrap read reveal">
        <p class="eyebrow">Il nome</p>
        <h2 id="name-h">Pole pole.</h2>
        <p class="lead">
          In swahili <em>«pole pole»</em> vuol dire piano piano: con calma, senza
          fretta.
        </p>
        <p>
          L’abbiamo sentito dire a Zanzibar. È diventato il modo in cui volevamo
          ci si sentisse, qui dentro. Il piccolo <Wordmark size="1.05em" /> è un
          gioco: <strong>Pole²</strong> = pole pole. Non serve capirlo subito —
          è lì, se un giorno vorrai scoprirlo.
        </p>
      </div>
    </section>

    <!-- ========================= WAITING LIST ========================= -->
    <section class="section section--alt" id="lista" aria-labelledby="wl-h">
      <div class="wrap read reveal">
        <p class="eyebrow">Ci sei anche tu</p>
        <h2 id="wl-h">Ti teniamo un posto.</h2>
        <p class="lead">
          Lascia la tua email. Ti scriveremo una volta soltanto, quando Pole²
          sarà pronto. Senza fretta.
        </p>
        <WaitlistForm />
      </div>
    </section>
  </main>

  <!-- ============================= FOOTER ============================= -->
  <footer class="footer">
    <div class="wrap footer__inner">
      <Wordmark size="1.4rem" />
      <p class="footer__line">Tutto resta sul tuo dispositivo.</p>
      <p class="footer__fine">© 2026 Pole²</p>
    </div>
  </footer>
</Base>

<style>
  /* -------------------------------- HERO -------------------------------- */
  .hero {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 20% 10%, #3a7c6d 0%, var(--petrol) 45%, var(--petrol-deep) 100%);
    color: var(--on-petrol);
    /* Fill the first screen, but never balloon on very tall monitors. */
    min-height: min(92svh, 920px);
    display: flex;
    align-items: center;
    padding-block: 4rem;
  }
  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  @media (min-width: 56rem) {
    .hero__grid {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }
  .hero__mark {
    color: var(--on-petrol);
    margin: 0 0 1.25rem;
  }
  .hero__tagline {
    font-size: clamp(1.35rem, 1.1rem + 1.2vw, 1.9rem);
    line-height: 1.25;
    font-weight: 500;
    margin: 0 0 1.25rem;
    color: var(--on-petrol);
    text-wrap: balance;
  }
  .hero__sentence {
    font-size: clamp(1.05rem, 1rem + 0.5vw, 1.3rem);
    color: var(--on-petrol-muted);
    max-width: 34rem;
    margin: 0 0 2rem;
  }
  .hero__cta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }
  .hero__reassure {
    margin: 0;
    font-size: 0.9rem;
    color: var(--on-petrol-muted);
  }
  .hero__turtle {
    display: flex;
    justify-content: center;
  }

  /* ----------------------------- NARRATIVE ------------------------------ */
  .narrative {
    padding-block: clamp(5rem, 11vw, 9rem);
  }
  .anxiety {
    font-family: 'Work Sans', 'Inter', sans-serif;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(2.4rem, 1.6rem + 4.5vw, 4.25rem);
    color: var(--petrol);
    margin: 0 0 2rem;
    text-wrap: balance;
  }
  @media (prefers-color-scheme: dark) {
    .anxiety {
      color: #7fd6be;
    }
  }
  .narrative__body p {
    font-size: clamp(1.15rem, 1rem + 0.7vw, 1.45rem);
    line-height: 1.55;
    max-width: 34rem;
  }
  .narrative__refrain {
    color: var(--muted);
  }

  /* ------------------------------- STEPS -------------------------------- */
  .steps {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
    gap: 1.25rem;
  }
  @media (min-width: 48rem) {
    .steps {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
  .steps__item {
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }
  .steps__mark {
    display: block;
    width: 0.85rem;
    height: 0.95rem;
    background: var(--gold);
    /* the shell motif, used sparingly as a quiet marker */
    clip-path: polygon(25% 0, 75% 0, 100% 50%, 75% 100%, 25% 100%, 0 50%);
  }
  .steps__item h3 {
    margin: 0.85rem 0 0.4rem;
  }
  .steps__item p {
    margin: 0;
    color: var(--muted);
  }

  /* ------------------------------ PRIVACY ------------------------------- */
  .privacy {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background:
      radial-gradient(120% 100% at 80% 0%, #2f6e5c 0%, var(--petrol) 55%, var(--petrol-deep) 100%);
    color: var(--on-petrol);
  }
  .privacy__inner {
    position: relative;
    z-index: 1;
  }
  .eyebrow--onPetrol {
    color: var(--gold);
  }
  .privacy h2 {
    color: var(--on-petrol);
  }
  .privacy__lead {
    font-size: clamp(1.15rem, 1rem + 0.7vw, 1.4rem);
    color: var(--on-petrol);
    margin: 0 0 0.5rem;
  }
  .privacy__list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: grid;
    gap: 0.9rem;
  }
  .privacy__list li {
    position: relative;
    padding-left: 1.9rem;
    font-size: 1.1rem;
  }
  .privacy__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.7rem;
    height: 0.7rem;
    background: var(--gold);
    /* a small hexagon bullet — the brand motif, used sparingly */
    clip-path: polygon(25% 0, 75% 0, 100% 50%, 75% 100%, 25% 100%, 0 50%);
  }
  .privacy__closing {
    margin-top: 1.75rem;
    color: var(--on-petrol-muted);
    font-style: italic;
  }

  /* ------------------------------- FOOTER ------------------------------- */
  .footer {
    border-top: 1px solid var(--hairline);
    padding-block: 2.5rem;
    color: var(--muted);
  }
  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer__line {
    margin: 0;
  }
  .footer__fine {
    margin: 0;
    font-size: 0.85rem;
    opacity: 0.8;
  }

  em {
    font-style: italic;
  }
</style>
