---
// Kobe — the guardian, in APPROVED canonical geometry (validation build k12).
// Reusable vector component (landing/app/icon/social).
//
// SHELL (the primary identity, one continuous surface):
//  · a clearly VERTICAL ellipse (width/height ≈ 0.86);
//  · a TRUE regular flat-top hexagon centred (the dorsal central scute);
//  · six radial joints — one through each hexagon vertex, out to the shell edge —
//    giving exactly 7 scutes: central + front, rear, front-L/R, rear-L/R
//    (front and rear are SINGLE scutes; there is no spine groove);
//  · plates are NEVER filled separately — the surface is one colour; separation
//    comes only from the GROUT joint: dark edge · light groove · dark edge
//    (a wide dark band with a narrow light band centred on it). The outer border
//    uses the same physical-edge construction;
//  · grooves widen imperceptibly toward the rim (subtle dome cue).
//
// BODY (secondary, separate dark forms attached under the shell): elongated
// teardrop HEAD, pointed triangular TAIL, and two equal-size leg pairs.
//
// MOTION (built, not required): the SHELL is the fixed anchor; head+tail rotate
// toward one side and the front+rear legs the opposite way, then reverse and
// settle. Rotation only — never translate/scale/bounce/loop; pauses on hidden
// tab; under Reduce Motion rotation is replaced by a brief shell highlight.
interface Props {
  size?: string;
  halo?: boolean;
  interactive?: boolean;
  label?: string;
  shell?: string; // continuous shell surface (light)
  body?: string; // head/legs/tail + grout dark edges + border (dark)
  grout?: string; // light groove channel between the dark edges
  class?: string;
  // Test seams (off in production): shorten the idle window / enable logging.
  idleMin?: number;
  idleSpan?: number;
  debug?: boolean;
}
const {
  size = '260px',
  halo = false,
  interactive = false,
  label = 'Kobe, la tartaruga di Pole²',
  shell = '#cfe8db',
  body = '#1f4638',
  grout = '#e7f4ee',
  class: cls = '',
  idleMin,
  idleSpan,
  debug = false,
} = Astro.props;

// ---- Geometry (k12 construction, refined proportions) ----------------------
const cx = 100, cy = 104, sc = 0.9; // shell uniformly scaled to 90%
const rx = +(57 * sc).toFixed(3), ry = +(66 * sc).toFixed(3); // vertical ellipse (0.86)
const R = 0.70 * rx; // central hexagon, enlarged to 0.70 of the shell width
const DEG = Math.PI / 180;
const f = (n: number) => n.toFixed(2);
const angs = [0, 60, 120, 180, 240, 300];
const V: Record<number, [number, number]> = {};
angs.forEach((a) => (V[a] = [cx + R * Math.cos(a * DEG), cy + R * Math.sin(a * DEG)]));

// radial ray from the shell centre through a vertex, out to the ellipse
function rayEllipse(px: number, py: number, dx: number, dy: number): [number, number] {
  const ax = px - cx, ay = py - cy;
  const A = (dx * dx) / (rx * rx) + (dy * dy) / (ry * ry);
  const B = 2 * ((ax * dx) / (rx * rx) + (ay * dy) / (ry * ry));
  const C = (ax * ax) / (rx * rx) + (ay * ay) / (ry * ry) - 1;
  const t = (-B + Math.sqrt(B * B - 4 * A * C)) / (2 * A);
  return [px + t * dx, py + t * dy];
}
const grooves: [[number, number], [number, number]][] = angs.map((a) => [
  V[a],
  rayEllipse(V[a][0], V[a][1], V[a][0] - cx, V[a][1] - cy),
]);

// tapered grout band (filled trapezoid centred on a joint): narrower at the
// centre (hIn), imperceptibly wider at the rim (hOut)
const dIn = 1.0 * sc, dOut = 1.3 * sc, lIn = 0.5 * sc, lOut = 0.78 * sc; // scaled with the shell
function band(Pi: [number, number], Po: [number, number], hIn: number, hOut: number): string {
  const dx = Po[0] - Pi[0], dy = Po[1] - Pi[1], L = Math.hypot(dx, dy) || 1, px = -dy / L, py = dx / L;
  return `M ${f(Pi[0] + px * hIn)} ${f(Pi[1] + py * hIn)} L ${f(Po[0] + px * hOut)} ${f(Po[1] + py * hOut)} L ${f(Po[0] - px * hOut)} ${f(Po[1] - py * hOut)} L ${f(Pi[0] - px * hIn)} ${f(Pi[1] - py * hIn)} Z`;
}
const darkBands = grooves.map(([a, b]) => band(a, b, dIn, dOut)).join(' ');
const lightBands = grooves.map(([a, b]) => band(a, b, lIn, lOut)).join(' ');
const hex = 'M ' + angs.map((a, i) => `${i ? 'L ' : ''}${f(V[a][0])} ${f(V[a][1])}`).join(' ') + ' Z';
const BW = 3.2 * sc, BIW = 1.4 * sc; // border grout (same principle as the joints)

// ---- Body forms (separate dark groups) -------------------------------------
// head enlarged (s ≈ 1.4) so it reads clearly as the head, still a calm teardrop
function headPath(hx: number, yBase: number, s: number): string {
  const nose = 10 * s, neck = 6 * s, H = 33 * s;
  const yN = yBase - H, nc = yN + nose, bh = neck * 2.0, yB = yBase + 6, yk = yBase - 6 * s;
  return `M ${hx - nose} ${nc} A ${nose} ${nose} 0 0 1 ${hx + nose} ${nc} C ${hx + nose} ${f(nc + H * 0.5)} ${hx + neck} ${f(yk - 4)} ${hx + neck} ${yk} C ${hx + neck} ${f(yk + 7)} ${hx + bh} ${f(yB - 6)} ${hx + bh} ${yB} L ${hx - bh} ${yB} C ${hx - bh} ${f(yB - 6)} ${hx - neck} ${f(yk + 7)} ${hx - neck} ${yk} C ${hx - neck} ${f(yk - 4)} ${hx - nose} ${f(nc + H * 0.5)} ${hx - nose} ${nc} Z`;
}
const head = headPath(cx, cy - ry + 13, 1.4);
const legShape = 'M -7 -9 Q -12 -10 -13 -3 Q -14 3 -10 8 Q -5 12 4 11 Q 13 10 15 2 Q 16 -6 9 -9 Q 1 -12 -7 -9 Z';
const leg = (x: number, y: number, rot: number) => `translate(${f(x)} ${f(y)}) rotate(${rot}) scale(1.05)`;
// front legs pulled up toward the head; rear legs pulled down toward the tail (same size)
const frontLegs = [
  leg(cx - rx * 0.86, cy - ry * 0.58, 208),
  leg(cx + rx * 0.86, cy - ry * 0.58, -28),
];
const rearLegs = [
  leg(cx - rx * 0.86, cy + ry * 0.66, 150),
  leg(cx + rx * 0.86, cy + ry * 0.66, 30),
];
const tail = `M ${cx - 5.5} ${f(cy + ry - 3)} Q ${cx} ${f(cy + ry + 2)} ${cx + 5.5} ${f(cy + ry - 3)} L ${cx} ${f(cy + ry + 15)} Z`;

const a11y = interactive
  ? { role: 'button', tabindex: '0', 'aria-label': label }
  : { 'aria-hidden': 'true' };
const dataAttrs = {
  ...(idleMin !== undefined ? { 'data-idle-min': String(idleMin) } : {}),
  ...(idleSpan !== undefined ? { 'data-idle-span': String(idleSpan) } : {}),
  ...(debug ? { 'data-debug': '' } : {}),
};
---
<span
  class={`kobe ${interactive ? 'kobe--interactive' : ''} ${cls}`.trim()}
  style={`--kobe-size:${size}`}
  {...a11y}
  {...dataAttrs}
>
  {halo && <span class="kobe__halo"></span>}
  <svg viewBox="0 0 200 200" role="img" aria-label={label} width="100%" height="100%">
    <defs>
      <clipPath id="kobeShell"><ellipse cx={cx} cy={cy} rx={rx} ry={ry}></ellipse></clipPath>
      <radialGradient id="kobeRim" cx="50%" cy="45%" r="60%">
        <stop offset="0.58" stop-color="#1d372f" stop-opacity="0"></stop>
        <stop offset="1" stop-color="#1d372f" stop-opacity="0.15"></stop>
      </radialGradient>
      <radialGradient id="kobeFlash" cx="50%" cy="46%" r="56%">
        <stop offset="0%" stop-color="#fbf6ea" stop-opacity="0.9"></stop>
        <stop offset="60%" stop-color="#e0a83d" stop-opacity="0.3"></stop>
        <stop offset="100%" stop-color="#e0a83d" stop-opacity="0"></stop>
      </radialGradient>
    </defs>

    <!-- Body = separate dark forms, UNDER the shell (attached, but distinct).
         Front + rear legs rebalance one way; head + tail the other. -->
    <g class="kobe-rear-legs">
      {rearLegs.map((t) => <path d={legShape} transform={t} fill={body}></path>)}
    </g>
    <g class="kobe-front-legs">
      {frontLegs.map((t) => <path d={legShape} transform={t} fill={body}></path>)}
    </g>
    <g class="kobe-tail"><path d={tail} fill={body}></path></g>
    <g class="kobe-head"><path d={head} fill={body}></path></g>

    <!-- SHELL: the FIXED anchor. One continuous surface + grout joints + border. -->
    <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill={shell}></ellipse>
    <g clip-path="url(#kobeShell)">
      <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill="url(#kobeRim)"></ellipse>
      <!-- grout joint: dark band, then light groove centred on it -->
      <path d={darkBands} fill={body}></path>
      <path d={hex} fill="none" stroke={body} stroke-width={2 * dIn} stroke-linejoin="round"></path>
      <path d={lightBands} fill={grout}></path>
      <path d={hex} fill="none" stroke={grout} stroke-width={2 * lIn} stroke-linejoin="round"></path>
      <ellipse class="kobe__flash" cx={cx} cy={cy} rx={rx} ry={ry} fill="url(#kobeFlash)"></ellipse>
    </g>
    <!-- outer border, same physical-edge construction (dark · light · dark) -->
    <g fill="none" stroke-linejoin="round">
      <ellipse cx={cx} cy={cy} rx={rx} ry={ry} stroke={body} stroke-width={BW}></ellipse>
      <ellipse cx={cx} cy={cy} rx={rx} ry={ry} stroke={grout} stroke-width={BIW}></ellipse>
    </g>

    <!-- Interactive hit target = the SHELL only. -->
    {interactive && <ellipse class="kobe-hit" cx={cx} cy={cy} rx={rx} ry={ry} fill="transparent"></ellipse>}
  </svg>
  {debug && <span class="kobe-debug" aria-hidden="true">debug…</span>}
</span>

<style>
  .kobe {
    position: relative;
    display: inline-block;
    width: var(--kobe-size);
    height: var(--kobe-size);
    max-width: 100%;
  }
  .kobe--interactive {
    -webkit-tap-highlight-color: transparent;
  }
  /* Only the shell is a pointer target; everything else passes through. */
  .kobe--interactive svg {
    pointer-events: none;
  }
  .kobe--interactive .kobe-hit {
    pointer-events: fill;
    cursor: pointer;
  }
  .kobe--interactive:focus-visible {
    outline: 2px solid #e0a83d;
    outline-offset: 6px;
    border-radius: 50%;
  }

  /* --- Debug mode (dev only; enabled by the `debug` prop) --------------- */
  .kobe[data-debug] .kobe-hit {
    fill: rgba(224, 168, 61, 0.1);
    stroke: #e0a83d;
    stroke-width: 1.4;
    stroke-dasharray: 4 3;
  }
  .kobe-debug {
    position: absolute;
    left: 50%;
    top: 100%;
    transform: translateX(-50%);
    margin-top: 10px;
    z-index: 3;
    pointer-events: none;
    font: 12px/1.4 ui-monospace, monospace;
    color: #fff;
    background: rgba(0, 0, 0, 0.6);
    padding: 6px 9px;
    border-radius: 6px;
    white-space: nowrap;
    text-align: center;
  }
  .kobe__halo {
    position: absolute;
    inset: -26%;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at 50% 46%,
      rgba(246, 241, 231, 0.16),
      rgba(246, 241, 231, 0.06) 42%,
      transparent 68%
    );
  }
  .kobe svg {
    position: relative;
    z-index: 1;
    display: block;
  }

  /* The shell is the fixed anchor; the body rebalances around the shell centre.
     Rotation only — no translate/scale/bounce/loop. */
  .kobe-head,
  .kobe-tail,
  .kobe-front-legs,
  .kobe-rear-legs {
    transform-box: view-box;
    transform-origin: 100px 104px;
  }

  /* Idle. Head + tail TIPS move to one side; the front AND rear legs move to the
     OPPOSITE side (each pair counter-rotates so all four end up together); then
     mirror; then settle. The shell never moves. */
  .kobe.playing-idle .kobe-head { animation: kobeHead 840ms ease-in-out both; }
  .kobe.playing-idle .kobe-tail { animation: kobeTail 840ms ease-in-out both; }
  .kobe.playing-idle .kobe-front-legs { animation: kobeFrontLegs 840ms ease-in-out both; }
  .kobe.playing-idle .kobe-rear-legs { animation: kobeRearLegs 840ms ease-in-out both; }
  @keyframes kobeHead {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(3.6deg); }
    72%, 86% { transform: rotate(-3.6deg); }
  }
  @keyframes kobeTail {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(-3.6deg); }
    72%, 86% { transform: rotate(3.6deg); }
  }
  @keyframes kobeFrontLegs {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(-2.4deg); }
    72%, 86% { transform: rotate(2.4deg); }
  }
  @keyframes kobeRearLegs {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(2.4deg); }
    72%, 86% { transform: rotate(-2.4deg); }
  }

  /* Reaction (click/tap): larger, clearly visible — "gently disturbed". */
  .kobe.reacting .kobe-head { animation: kobeReactHead 780ms ease-in-out both; }
  .kobe.reacting .kobe-tail { animation: kobeReactTail 780ms ease-in-out both; }
  .kobe.reacting .kobe-front-legs { animation: kobeReactFrontLegs 780ms ease-in-out both; }
  .kobe.reacting .kobe-rear-legs { animation: kobeReactRearLegs 780ms ease-in-out both; }
  @keyframes kobeReactHead {
    0%, 100% { transform: rotate(0deg); }
    35% { transform: rotate(6.6deg); }
    70% { transform: rotate(-4.2deg); }
  }
  @keyframes kobeReactTail {
    0%, 100% { transform: rotate(0deg); }
    35% { transform: rotate(-6.6deg); }
    70% { transform: rotate(4.2deg); }
  }
  @keyframes kobeReactFrontLegs {
    0%, 100% { transform: rotate(0deg); }
    35% { transform: rotate(-4.2deg); }
    70% { transform: rotate(2.7deg); }
  }
  @keyframes kobeReactRearLegs {
    0%, 100% { transform: rotate(0deg); }
    35% { transform: rotate(4.2deg); }
    70% { transform: rotate(-2.7deg); }
  }

  /* Reduce Motion: no rotation. The reaction becomes a brief shell highlight;
     the idle cue does not run. */
  .kobe__flash {
    opacity: 0;
  }
  @keyframes kobeFlash {
    0% { opacity: 0; }
    40% { opacity: 0.32; }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .kobe-head,
    .kobe-tail,
    .kobe-front-legs,
    .kobe-rear-legs {
      animation: none !important;
      transform: none !important;
    }
    .kobe.reacting .kobe__flash {
      animation: kobeFlash 420ms ease-out;
    }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const IDLE_MS = 900; // idle animation length
  const REACT_MS = 820; // reaction animation length

  document.querySelectorAll<HTMLElement>('.kobe').forEach((kobe) => {
    // Idle window (production defaults; overridable for testing via data-*).
    const idleMin = kobe.dataset.idleMin !== undefined ? Number(kobe.dataset.idleMin) : 25000;
    const idleSpan = kobe.dataset.idleSpan !== undefined ? Number(kobe.dataset.idleSpan) : 25000;
    const debug = kobe.dataset.debug !== undefined;
    const log = (...a: unknown[]) => debug && console.log('[kobe]', ...a);
    const dbg = kobe.querySelector('.kobe-debug');
    const rm = () => (reduce ? 'REDUCE-MOTION ON — rotation suppressed' : 'reduce-motion off');
    const setDbg = (s: string) => {
      if (dbg) dbg.textContent = `${rm()} · ${s}`;
    };
    setDbg('init');

    // Exactly one idle timer at a time.
    let idleTimer: number | undefined;
    let reacting = false;

    const clearIdle = () => {
      window.clearTimeout(idleTimer);
      idleTimer = undefined;
    };
    const scheduleIdle = () => {
      clearIdle(); // never allow concurrent timers
      if (reduce || document.hidden || reacting) return;
      const delay = idleMin + Math.random() * idleSpan;
      idleTimer = window.setTimeout(playIdle, delay);
      log('idle scheduled in', Math.round(delay), 'ms');
      setDbg(`idle scheduled in ${(delay / 1000).toFixed(1)}s`);
    };
    const playIdle = () => {
      idleTimer = undefined;
      if (reduce || document.hidden || reacting) return scheduleIdle();
      log('idle play');
      setDbg('idle ▶ playing');
      kobe.classList.add('playing-idle');
      window.setTimeout(() => {
        kobe.classList.remove('playing-idle');
        scheduleIdle(); // after every idle animation, a new random delay
      }, IDLE_MS);
    };

    // Reaction: only from a direct click/tap on the shell (or keyboard). Cancels
    // the idle timer, plays, then starts a fresh idle delay. Ignores repeat input
    // until it finishes (no stacking).
    const react = () => {
      if (reacting) return;
      reacting = true;
      clearIdle();
      kobe.classList.remove('playing-idle');
      log('reaction');
      setDbg('shell click ✓ → reacting');
      kobe.classList.add('reacting');
      window.setTimeout(() => {
        kobe.classList.remove('reacting');
        reacting = false;
        scheduleIdle();
      }, REACT_MS);
    };

    if (kobe.classList.contains('kobe--interactive')) {
      // Pointer/touch: only the shell hit-ellipse triggers the reaction.
      kobe.querySelector('.kobe-hit')?.addEventListener('click', react);
      // Keyboard activation of the focused guardian.
      kobe.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault(); // Space must not scroll the page
          react();
        }
      });
    }

    // The idle timer is NOT reset by general page interaction. It only resets on
    // a direct shell click (above) or after an automatic idle animation. It is
    // suspended while the tab is hidden.
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        clearIdle();
        log('hidden: timer suspended');
        setDbg('tab hidden — timer suspended');
      } else {
        log('visible: reschedule');
        scheduleIdle();
      }
    });

    scheduleIdle();
  });
</script>
