---
// Kobe — the guardian, in canonical geometry (see docs/BRAND_BIBLE.md
// "Kobe Canonical Geometry"). Reusable vector component (landing/app/icon/social).
//
// Shell: an ELLIPSE (h/v ratio 0.90), FULLY TESSELLATED with one regular hex grid
// centred on a cell and CLIPPED by the ellipse; the canonical core (1 central + 6
// surrounding complete hexagons) is always recognizable, with more cells to the
// clipped edge. Head: a rounded, elongated BULLET. Tail: short, TRIANGULAR,
// clearly POINTED, centred on the vertical axis (the only pointed body element).
// Four soft diagonal limbs.
//
// Motion (canonical — BRAND_BIBLE §13a): the SHELL is a fixed pivot; head+tail
// rotate one way and the limbs the opposite way around the shell centre.
//  - idle: a small posture adjustment after ~25–50s of inactivity
//  - reaction: a larger, clearly-visible "you gently disturbed me" on click/tap
// Rotation only — never translate/scale/bounce/loop; pauses on hidden tab; off
// (rotation replaced by a brief shell highlight) under Reduce Motion.
interface Props {
  size?: string;
  halo?: boolean;
  interactive?: boolean;
  label?: string;
  shell?: string;
  body?: string;
  line?: string;
  class?: string;
}
const {
  size = '260px',
  halo = false,
  interactive = false,
  label = 'Kobe, la tartaruga di Pole²',
  shell = '#a7ded0',
  body = '#123f34',
  line = 'rgba(18,63,52,0.5)',
  class: cls = '',
} = Astro.props;

const cx = 100, cy = 104, ry = 52;
const rx = +(ry * 0.9).toFixed(2); // 46.8 — the 0.90 invariant

// continuous hex tessellation, centred on a cell, clipped to the ellipse
const hexR = 15;
const hStep = 1.5 * hexR;
const vStep = Math.sqrt(3) * hexR;
function hexPath(x: number, y: number, r: number) {
  let d = '';
  for (let i = 0; i < 6; i++) {
    const a = (60 * i * Math.PI) / 180;
    d += (i === 0 ? 'M' : 'L') + (x + r * Math.cos(a)).toFixed(2) + ' ' + (y + r * Math.sin(a)).toFixed(2) + ' ';
  }
  return d + 'Z';
}
const cells: [number, number][] = [];
for (let col = -4; col <= 4; col++) {
  for (let row = -4; row <= 4; row++) {
    const x = cx + col * hStep;
    const y = cy + row * vStep + (col % 2 !== 0 ? vStep / 2 : 0);
    if (((x - cx) / (rx + hexR)) ** 2 + ((y - cy) / (ry + hexR)) ** 2 <= 1) cells.push([x, y]);
  }
}
const scutes = cells.map(([x, y]) => hexPath(x, y, hexR)).join('');

// rounded, elongated bullet head
const hTop = 26, hBot = 58, hL = 89, hR = 111, topR = 11, botR = 7;
const head = `M ${hL} ${hTop + topR} A ${topR} ${topR} 0 0 1 ${hR} ${hTop + topR} L ${hR} ${hBot - botR} A ${botR} ${botR} 0 0 1 ${hR - botR} ${hBot} L ${hL + botR} ${hBot} A ${botR} ${botR} 0 0 1 ${hL} ${hBot - botR} Z`;

// short, pointed, triangular tail — centred on the vertical axis
const tail = `${cx - 7},${cy + ry - 4} ${cx + 7},${cy + ry - 4} ${cx},${cy + ry + 13}`;

// limbs (soft ovals) at the diagonals
const limbs = [-52, -128, 52, 128].map((deg) => {
  const a = (deg * Math.PI) / 180;
  return { x: +(cx + rx * Math.cos(a)).toFixed(1), y: +(cy + ry * Math.sin(a)).toFixed(1) };
});

const a11y = interactive
  ? { role: 'button', tabindex: '0', 'aria-label': label }
  : { 'aria-hidden': 'true' };
---
<span
  class={`kobe ${interactive ? 'kobe--interactive' : ''} ${cls}`.trim()}
  style={`--kobe-size:${size}`}
  {...a11y}
>
  {halo && <span class="kobe__halo"></span>}
  <svg viewBox="0 0 200 200" role="img" aria-label="Kobe, la tartaruga di Pole²" width="100%" height="100%">
    <defs>
      <clipPath id="kobeShell"><ellipse cx={cx} cy={cy} rx={rx} ry={ry}></ellipse></clipPath>
      <radialGradient id="kobeSatin" cx="34%" cy="30%" r="60%">
        <stop offset="0%" stop-color="#f6f1e7" stop-opacity="0.22"></stop>
        <stop offset="100%" stop-color="#f6f1e7" stop-opacity="0"></stop>
      </radialGradient>
      <radialGradient id="kobeFlash" cx="50%" cy="46%" r="56%">
        <stop offset="0%" stop-color="#fbf6ea" stop-opacity="0.9"></stop>
        <stop offset="60%" stop-color="#e0a83d" stop-opacity="0.3"></stop>
        <stop offset="100%" stop-color="#e0a83d" stop-opacity="0"></stop>
      </radialGradient>
    </defs>

    <!-- limbs rebalance the opposite way — under the shell -->
    <g class="kobe-limbs">
      {limbs.map((l) => <ellipse cx={l.x} cy={l.y} rx="9" ry="11" fill={body}></ellipse>)}
    </g>
    <!-- head + pointed tail rotate together around the shell centre — under the shell -->
    <g class="kobe-spine">
      <polygon points={tail} fill={body}></polygon>
      <path d={head} fill={body}></path>
    </g>

    <!-- shell: the FIXED pivot — dome + tessellated scutes + satin + (flash) + rim -->
    <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill={shell}></ellipse>
    <g clip-path="url(#kobeShell)">
      <path d={scutes} fill="none" stroke={line} stroke-width="1.6"></path>
      <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill="url(#kobeSatin)"></ellipse>
      <ellipse class="kobe__flash" cx={cx} cy={cy} rx={rx} ry={ry} fill="url(#kobeFlash)"></ellipse>
    </g>
    <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill="none" stroke={body} stroke-width="3.2"></ellipse>
  </svg>
</span>

<style>
  .kobe {
    position: relative;
    display: inline-block;
    width: var(--kobe-size);
    height: var(--kobe-size);
    max-width: 100%;
  }
  .kobe--interactive {
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }
  .kobe--interactive:focus-visible {
    outline: 2px solid #e0a83d;
    outline-offset: 6px;
    border-radius: 50%;
  }
  .kobe__halo {
    position: absolute;
    inset: -26%;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at 50% 46%,
      rgba(246, 241, 231, 0.16),
      rgba(246, 241, 231, 0.06) 42%,
      transparent 68%
    );
  }
  .kobe svg {
    position: relative;
    z-index: 1;
    display: block;
  }

  /* The shell is the fixed pivot; the body rebalances around the shell centre.
     Rotation only — no translate/scale/bounce/loop. */
  .kobe-spine,
  .kobe-limbs {
    transform-box: view-box;
    transform-origin: 100px 104px;
  }

  /* Idle: a small posture adjustment (played by the script). */
  .kobe.playing-idle .kobe-spine {
    animation: kobeSpine 840ms ease-in-out both;
  }
  .kobe.playing-idle .kobe-limbs {
    animation: kobeLimbs 840ms ease-in-out both;
  }
  @keyframes kobeSpine {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(3.6deg); }
    72%, 86% { transform: rotate(-3.6deg); }
  }
  @keyframes kobeLimbs {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(-2.1deg); }
    72%, 86% { transform: rotate(2.1deg); }
  }

  /* Reaction (click/tap): larger, clearly visible — "gently disturbed". Head+tail
     swing to one side, limbs the opposite way, a brief reverse, then settle. */
  .kobe.reacting .kobe-spine {
    animation: kobeReactSpine 780ms ease-in-out both;
  }
  .kobe.reacting .kobe-limbs {
    animation: kobeReactLimbs 780ms ease-in-out both;
  }
  @keyframes kobeReactSpine {
    0%, 100% { transform: rotate(0deg); }
    35% { transform: rotate(8.5deg); }
    70% { transform: rotate(-4.5deg); }
  }
  @keyframes kobeReactLimbs {
    0%, 100% { transform: rotate(0deg); }
    35% { transform: rotate(-5deg); }
    70% { transform: rotate(2.7deg); }
  }

  /* Reduce Motion: no rotation. The reaction becomes a brief, subtle shell
     highlight; the idle cue does not run. */
  .kobe__flash {
    opacity: 0;
  }
  @keyframes kobeFlash {
    0% { opacity: 0; }
    40% { opacity: 0.32; }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .kobe-spine,
    .kobe-limbs {
      animation: none !important;
      transform: none !important;
    }
    .kobe.reacting .kobe__flash {
      animation: kobeFlash 420ms ease-out;
    }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const IDLE_MS = 900;
  const REACT_MS = 820;

  document.querySelectorAll<HTMLElement>('.kobe').forEach((kobe) => {
    let idleTimer: number | undefined;
    let reacting = false;

    const scheduleIdle = () => {
      window.clearTimeout(idleTimer);
      if (reduce || document.hidden || reacting) return;
      idleTimer = window.setTimeout(playIdle, 25000 + Math.random() * 25000);
    };
    const playIdle = () => {
      if (reduce || document.hidden || reacting) return scheduleIdle();
      kobe.classList.add('playing-idle');
      window.setTimeout(() => {
        kobe.classList.remove('playing-idle');
        scheduleIdle();
      }, IDLE_MS);
    };

    // Reaction: ignore further input until the current one finishes (no stacking).
    const react = () => {
      if (reacting) return;
      reacting = true;
      window.clearTimeout(idleTimer); // stop the passive idle cue while reacting
      kobe.classList.remove('playing-idle');
      kobe.classList.add('reacting');
      window.setTimeout(() => {
        kobe.classList.remove('reacting');
        reacting = false;
        scheduleIdle();
      }, REACT_MS);
    };

    if (kobe.classList.contains('kobe--interactive')) {
      kobe.addEventListener('click', react);
      kobe.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault(); // Space must not scroll the page
          react();
        }
      });
    }

    // Reset the idle window on genuine activity (throttled), so it only stirs
    // when things are calm. Never interrupts a movement in progress.
    let last = 0;
    const onActivity = () => {
      const now = Date.now();
      if (now - last < 1500) return;
      last = now;
      if (!reacting && !kobe.classList.contains('playing-idle')) scheduleIdle();
    };
    for (const ev of ['pointerdown', 'keydown', 'scroll', 'pointermove']) {
      window.addEventListener(ev, onActivity, { passive: true });
    }
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) window.clearTimeout(idleTimer);
      else scheduleIdle();
    });

    scheduleIdle();
  });
</script>
