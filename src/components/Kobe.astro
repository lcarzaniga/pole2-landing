---
// Kobe — the guardian, in canonical geometry (see docs/BRAND_BIBLE.md
// "Kobe Canonical Geometry"). Reusable vector component so the same Kobe can be
// used across landing, app, icon and social images.
//
// Shell construction:
//  - the shell is an ELLIPSE, horizontal/vertical axis ratio = 0.90 (taller than wide)
//  - it is FULLY TESSELLATED with one regular hex grid, centred on a cell, and
//    the tessellation is CLIPPED by the ellipse (outer cells are naturally cut)
//  - the canonical core — 1 central + 6 surrounding complete hexagons — is always
//    present and recognizable at the centre; additional cells continue to the edge
//  - head is a rounded BULLET; four soft diagonal limbs; a small rounded tail nub
//
// Idle behaviour (canonical — see BRAND_BIBLE "Kobe idle animation"):
//  - after ~25–50s of inactivity, ONE calm posture adjustment
//  - the SHELL is the fixed pivot; head+tail rotate a few degrees to one side and
//    the four limbs rotate slightly the opposite way, brief pause, sway to the
//    other side, then settle back to rest (~840ms, ease-in-out)
//  - rotation only — never translate/scale/bounce/loop; pauses on hidden tab;
//    off under Reduce Motion.
interface Props {
  size?: string;
  halo?: boolean;
  shell?: string;
  body?: string;
  line?: string;
  class?: string;
}
const {
  size = '260px',
  halo = false,
  shell = '#a7ded0',
  body = '#123f34',
  line = 'rgba(18,63,52,0.5)',
  class: cls = '',
} = Astro.props;

// --- shell ellipse (ratio 0.90) ---
const cx = 100;
const cy = 104;
const ry = 52;
const rx = +(ry * 0.9).toFixed(2); // 46.8 — the 0.90 invariant

// --- continuous hex tessellation, centred on a cell, clipped to the ellipse ---
const hexR = 15;
const hStep = 1.5 * hexR;
const vStep = Math.sqrt(3) * hexR;
function hexPath(x: number, y: number, r: number) {
  let d = '';
  for (let i = 0; i < 6; i++) {
    const a = (60 * i * Math.PI) / 180; // flat-top
    d += (i === 0 ? 'M' : 'L') + (x + r * Math.cos(a)).toFixed(2) + ' ' + (y + r * Math.sin(a)).toFixed(2) + ' ';
  }
  return d + 'Z';
}
const cells: [number, number][] = [];
for (let col = -4; col <= 4; col++) {
  for (let row = -4; row <= 4; row++) {
    const x = cx + col * hStep;
    const y = cy + row * vStep + (col % 2 !== 0 ? vStep / 2 : 0);
    if (((x - cx) / (rx + hexR)) ** 2 + ((y - cy) / (ry + hexR)) ** 2 <= 1) {
      cells.push([x, y]);
    }
  }
}
const scutes = cells.map(([x, y]) => hexPath(x, y, hexR)).join('');

// --- rounded bullet head (domed top, softly rounded base) ---
const hTop = 26, hBot = 58, hL = 89, hR = 111, topR = 11, botR = 7;
const head = `M ${hL} ${hTop + topR} A ${topR} ${topR} 0 0 1 ${hR} ${hTop + topR} L ${hR} ${hBot - botR} A ${botR} ${botR} 0 0 1 ${hR - botR} ${hBot} L ${hL + botR} ${hBot} A ${botR} ${botR} 0 0 1 ${hL} ${hBot - botR} Z`;

// --- limbs (soft ovals) at the diagonals + tail nub ---
const limbs = [-52, -128, 52, 128].map((deg) => {
  const a = (deg * Math.PI) / 180;
  return { x: +(cx + rx * Math.cos(a)).toFixed(1), y: +(cy + ry * Math.sin(a)).toFixed(1) };
});
---
<span class={`kobe ${cls}`} style={`--kobe-size:${size}`} aria-hidden="true">
  {halo && <span class="kobe__halo"></span>}
  <svg viewBox="0 0 200 200" role="img" aria-label="Kobe, la tartaruga di Pole²" width="100%" height="100%">
    <defs>
      <clipPath id="kobeShell"><ellipse cx={cx} cy={cy} rx={rx} ry={ry}></ellipse></clipPath>
      <radialGradient id="kobeSatin" cx="34%" cy="30%" r="60%">
        <stop offset="0%" stop-color="#f6f1e7" stop-opacity="0.22"></stop>
        <stop offset="100%" stop-color="#f6f1e7" stop-opacity="0"></stop>
      </radialGradient>
    </defs>

    <!-- limbs (rebalance the opposite way) — under the shell -->
    <g class="kobe-limbs">
      {limbs.map((l) => <ellipse cx={l.x} cy={l.y} rx="9" ry="11" fill={body}></ellipse>)}
    </g>
    <!-- head + tail rotate together around the shell centre — under the shell -->
    <g class="kobe-spine">
      <ellipse cx={cx} cy={cy + ry} rx="6.5" ry="9" fill={body}></ellipse>
      <path d={head} fill={body}></path>
    </g>

    <!-- shell: the FIXED pivot — elliptical dome + tessellated scutes + satin + rim -->
    <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill={shell}></ellipse>
    <g clip-path="url(#kobeShell)">
      <path d={scutes} fill="none" stroke={line} stroke-width="1.6"></path>
      <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill="url(#kobeSatin)"></ellipse>
    </g>
    <ellipse cx={cx} cy={cy} rx={rx} ry={ry} fill="none" stroke={body} stroke-width="3.2"></ellipse>
  </svg>
</span>

<style>
  .kobe {
    position: relative;
    display: inline-block;
    width: var(--kobe-size);
    height: var(--kobe-size);
    max-width: 100%;
  }
  /* A very soft warm halo — helps Kobe emerge from the petrol hero without any
     outline, spotlight or shadow. Optional (hero only). */
  .kobe__halo {
    position: absolute;
    inset: -26%;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at 50% 46%,
      rgba(246, 241, 231, 0.16),
      rgba(246, 241, 231, 0.06) 42%,
      transparent 68%
    );
  }
  .kobe svg {
    position: relative;
    z-index: 1;
    display: block;
  }

  /* Idle posture adjustment. The shell stays still; the body rebalances around
     the shell centre. Rotation only — no translate/scale/bounce/loop. Played
     once per idle period by the script below (adds `.playing`). */
  .kobe-spine,
  .kobe-limbs {
    transform-box: view-box;
    transform-origin: 100px 104px;
  }
  .kobe.playing .kobe-spine {
    animation: kobeSpine 840ms ease-in-out both;
  }
  .kobe.playing .kobe-limbs {
    animation: kobeLimbs 840ms ease-in-out both;
  }
  /* rest → side A → (hold) → through to side B → (hold) → settle to rest */
  @keyframes kobeSpine {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(3.6deg); }
    72%, 86% { transform: rotate(-3.6deg); }
  }
  @keyframes kobeLimbs {
    0%, 100% { transform: rotate(0deg); }
    28%, 42% { transform: rotate(-2.1deg); }
    72%, 86% { transform: rotate(2.1deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .kobe-spine,
    .kobe-limbs {
      animation: none !important;
      transform: none !important;
    }
  }
</style>

<script>
  // Canonical idle: one calm posture adjustment after ~25–50s of inactivity.
  // Rotation only; pauses on hidden tab; never runs under Reduce Motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const DURATION = 900; // a touch longer than the animation, to clear the class
  document.querySelectorAll<HTMLElement>('.kobe').forEach((kobe) => {
    if (reduce) return;
    let timer: number | undefined;

    const schedule = () => {
      window.clearTimeout(timer);
      if (document.hidden) return;
      timer = window.setTimeout(play, 25000 + Math.random() * 25000);
    };
    const play = () => {
      if (document.hidden) return schedule();
      kobe.classList.add('playing');
      window.setTimeout(() => {
        kobe.classList.remove('playing');
        schedule();
      }, DURATION);
    };

    // Reset the idle window on real activity (throttled), so it only stirs when
    // things are actually calm. Never interrupts a movement in progress.
    let last = 0;
    const onActivity = () => {
      const now = Date.now();
      if (now - last < 1500) return;
      last = now;
      if (!kobe.classList.contains('playing')) schedule();
    };
    for (const ev of ['pointerdown', 'keydown', 'scroll', 'pointermove']) {
      window.addEventListener(ev, onActivity, { passive: true });
    }
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) window.clearTimeout(timer);
      else schedule();
    });

    schedule();
  });
</script>
