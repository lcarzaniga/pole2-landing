---
import Wordmark from './Wordmark.astro';
import { STRINGS, localeFromPath, localizedPath } from '../i18n';

const locale = localeFromPath(Astro.url.pathname);
const s = STRINGS[locale];
const p = (b: string) => localizedPath(b, locale);
---

<footer class="footer">
  <div class="wrap footer__inner">
    <Wordmark size="1.4rem" />
    <nav class="footer__nav" aria-label={s.nav.pagesLabel}>
      <a href={p('/guida')}>{s.nav.guide}</a>
      <a href={p('/supporto')}>{s.nav.support}</a>
      <a href={p('/privacy')}>{s.nav.privacy}</a>
      <a href={p('/novita')}>{s.nav.news}</a>
    </nav>
    <p class="footer__line">{s.footerLine}</p>
    <p class="footer__fine">© 2026 Pole²</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--hairline);
    padding-block: 2.5rem;
    color: var(--muted);
  }
  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1.25rem;
    margin: 0.35rem 0 0.15rem;
  }
  .footer__nav a {
    color: var(--muted);
    text-decoration: none;
  }
  .footer__nav a:hover {
    color: var(--ink);
    text-decoration: underline;
  }
  .footer__line {
    margin: 0;
  }
  .footer__fine {
    margin: 0;
    font-size: 0.85rem;
    opacity: 0.8;
  }
</style>
