---
// Waiting-list form. Real backend: POSTs the email (form-encoded) to the
// Cloudflare Pages Function at /api/waitlist, which is the source of truth. The
// calm confirmation is shown ONLY after a durable 2xx from the Function — there
// is no local "fake success" fallback. Progressive: without JS it is real HTML
// that posts natively to the same endpoint.
import Turnstile from './Turnstile.astro';
import { STRINGS, localeFromPath, localizedPath } from '../i18n';

const locale = localeFromPath(Astro.url.pathname);
const w = STRINGS[locale].waitlist;
const privacyHref = localizedPath('/privacy', locale);
---

<form
  class="waitlist"
  action="/api/waitlist"
  method="post"
  novalidate
  data-check-email={w.checkEmail}
  data-need-consent={w.needConsent}
  data-success={w.success}
  data-fail={w.fail}
>
  <label class="waitlist__label" for="wl-email">{w.label}</label>
  <div class="waitlist__row">
    <input
      id="wl-email"
      class="waitlist__input"
      type="email"
      name="email"
      inputmode="email"
      autocomplete="email"
      placeholder={w.placeholder}
      required
      aria-describedby="wl-note wl-status"
    />
    <button class="btn btn--primary waitlist__submit" type="submit">
      {w.submit}
    </button>
  </div>

  <!-- Honeypot: hidden from people, tempting to bots. Left empty by humans. -->
  <div class="waitlist__hp" aria-hidden="true">
    <label>{w.hpLabel}
      <input type="text" name="company" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <label class="waitlist__consent">
    <input type="checkbox" name="consent" value="on" required />
    <span>
      {w.consent} <a href={privacyHref}>{w.privacyLink}</a>.
    </span>
  </label>

  <Turnstile />

  <p id="wl-note" class="waitlist__note">{w.note}</p>
  <p id="wl-status" class="waitlist__status" role="status" aria-live="polite"></p>
</form>

<style>
  .waitlist {
    margin-top: 1.5rem;
  }
  .waitlist__label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .waitlist__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .waitlist__input {
    flex: 1 1 16rem;
    min-width: 0;
    font: inherit;
    color: var(--ink);
    background: var(--surface);
    border: 1.5px solid var(--hairline);
    border-radius: 999px;
    padding: 0.9rem 1.25rem;
    transition: border-color 0.2s ease;
  }
  .waitlist__input:focus {
    border-color: var(--petrol);
  }
  .waitlist__input[aria-invalid='true'] {
    border-color: #b3452f;
  }
  .waitlist__submit {
    flex: 0 0 auto;
  }
  .waitlist__submit:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .waitlist__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .waitlist__consent {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    margin-top: 1rem;
    font-size: 0.95rem;
    color: var(--muted);
  }
  .waitlist__consent input {
    margin-top: 0.2rem;
    flex: 0 0 auto;
  }
  .waitlist__note {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .waitlist__status {
    margin-top: 0.5rem;
    font-weight: 500;
    min-height: 1.4em;
    color: var(--petrol);
  }
  @media (prefers-color-scheme: dark) {
    .waitlist__status {
      color: #7fd6be;
    }
  }
  .waitlist.is-done .waitlist__row,
  .waitlist.is-done .waitlist__consent,
  .waitlist.is-done .cf-turnstile,
  .waitlist.is-done .waitlist__note {
    display: none;
  }
  @media (max-width: 30rem) {
    .waitlist__submit {
      width: 100%;
    }
  }
</style>

<script>
  // Real submission with calm states. Success is shown ONLY on a durable 2xx.
  const form = document.querySelector<HTMLFormElement>('.waitlist');
  if (form) {
    const input = form.querySelector<HTMLInputElement>('#wl-email')!;
    const consent = form.querySelector<HTMLInputElement>('input[name="consent"]')!;
    const button = form.querySelector<HTMLButtonElement>('.waitlist__submit')!;
    const status = form.querySelector<HTMLParagraphElement>('#wl-status')!;
    const t = (k: string, fallback: string) => form.dataset[k] || fallback;
    let pending = false;

    const say = (msg: string) => {
      status.textContent = msg;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (pending) return; // no duplicate submission while a request is in flight
      input.setAttribute('aria-invalid', 'false');

      if (!input.value || !input.checkValidity()) {
        input.setAttribute('aria-invalid', 'true');
        say(t('checkEmail', 'Check the email address and try again.'));
        input.focus();
        return;
      }
      if (!consent.checked) {
        say(t('needConsent', 'We need your consent to save you a spot.'));
        consent.focus();
        return;
      }

      pending = true;
      button.disabled = true;
      say('…');
      try {
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as any).toString(),
        });
        if (!res.ok) throw new Error(String(res.status));
        // Durable success confirmed by the backend.
        form.classList.add('is-done');
        say(t('success', 'Your spot is saved.'));
        status.focus?.();
      } catch {
        // Never claim the place was saved. Keep the typed email; allow a retry.
        say(t('fail', 'Nothing was lost. Try again whenever you like.'));
        button.disabled = false;
      } finally {
        pending = false;
      }
    });
  }
</script>
