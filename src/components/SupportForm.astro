---
// Support / bug-report form. POSTs (form-encoded) to /api/support, which writes
// to D1 (source of truth) and notifies support out-of-band. Success is shown
// ONLY after a durable 2xx. A client-generated submission id makes retries
// idempotent. app version/build are prefilled from ?v= and ?b=.
import Turnstile from './Turnstile.astro';
import {
  STRINGS,
  SUPPORT_TOPICS,
  SUPPORT_TOPIC_LABELS,
  localeFromPath,
  localizedPath,
} from '../i18n';

const locale = localeFromPath(Astro.url.pathname);
const sp = STRINGS[locale].support;
const topics = SUPPORT_TOPIC_LABELS[locale];
const privacyHref = localizedPath('/privacy', locale);
const hint =
  locale === 'it'
    ? 'Non inviare backup, fotografie o informazioni personali sulle cose che conservi in Pole².'
    : 'Don’t send backups, photos or personal information about the things you keep in Pole².';
const consentTail =
  locale === 'it'
    ? ' e acconsento al trattamento dei dati per rispondere alla mia richiesta.'
    : ' and consent to my data being processed to answer my request.';
---

<form
  class="support-form"
  action="/api/support"
  method="post"
  novalidate
  data-check-email={sp.checkEmail}
  data-too-short={sp.tooShort}
  data-success={sp.success}
  data-fail={sp.fail}
>
  <input type="hidden" name="submission_id" value="" />

  <div class="field">
    <label class="field__label" for="sp-email">{sp.emailLabel}</label>
    <input
      id="sp-email"
      class="field__input"
      type="email"
      name="email"
      inputmode="email"
      autocomplete="email"
      placeholder={STRINGS[locale].waitlist.placeholder}
      required
    />
  </div>

  <div class="field">
    <label class="field__label" for="sp-category">{sp.topicLabel}</label>
    <!-- The VALUE is a stable topic key; the label is localized. The server
         validates the key, never the translated text. -->
    <select id="sp-category" class="field__input" name="category" required>
      {
        SUPPORT_TOPICS.map((key) => (
          <option value={key}>{topics[key]}</option>
        ))
      }
    </select>
  </div>

  <div class="field">
    <label class="field__label" for="sp-message">{sp.messageLabel}</label>
    <textarea
      id="sp-message"
      class="field__input field__textarea"
      name="message"
      rows="7"
      minlength="10"
      maxlength="4000"
      required
      placeholder={sp.messagePlaceholder}
    ></textarea>
    <p class="field__hint">{hint}</p>
  </div>

  <div class="field field--inline">
    <div>
      <label class="field__label" for="sp-version">{sp.versionLabel}</label>
      <input id="sp-version" class="field__input" type="text" name="app_version" maxlength="32" autocomplete="off" />
    </div>
    <div>
      <label class="field__label" for="sp-build">{sp.buildLabel}</label>
      <input id="sp-build" class="field__input" type="text" name="app_build" maxlength="16" autocomplete="off" />
    </div>
  </div>

  <!-- Honeypot -->
  <div class="support-form__hp" aria-hidden="true">
    <label>{sp.hpLabel}
      <input type="text" name="company" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <label class="support-form__consent">
    <input type="checkbox" name="privacy" value="on" required />
    <span>
      {sp.consent} <a href={privacyHref}>{sp.privacyLink}</a>{consentTail}
    </span>
  </label>

  <Turnstile />

  <div class="support-form__actions">
    <button class="btn btn--primary" type="submit">{sp.submit}</button>
  </div>

  <p id="sp-status" class="support-form__status" role="status" aria-live="polite"></p>
</form>

<style>
  .support-form {
    margin-top: 1.5rem;
    display: grid;
    gap: 1.1rem;
    max-width: 40rem;
  }
  .field__label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.4rem;
  }
  .field__input {
    width: 100%;
    font: inherit;
    color: var(--ink);
    background: var(--surface);
    border: 1.5px solid var(--hairline);
    border-radius: 14px;
    padding: 0.8rem 1rem;
    transition: border-color 0.2s ease;
  }
  .field__input:focus {
    border-color: var(--petrol);
  }
  .field__input[aria-invalid='true'] {
    border-color: #b3452f;
  }
  .field__textarea {
    resize: vertical;
    min-height: 8rem;
    line-height: 1.5;
  }
  .field__hint {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .field--inline {
    display: grid;
    gap: 1rem;
  }
  @media (min-width: 30rem) {
    .field--inline {
      grid-template-columns: 1fr 1fr;
    }
  }
  .support-form__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .support-form__consent {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.95rem;
    color: var(--muted);
  }
  .support-form__consent input {
    margin-top: 0.2rem;
    flex: 0 0 auto;
  }
  .support-form__status {
    margin: 0;
    min-height: 1.4em;
    font-weight: 500;
    color: var(--petrol);
  }
  @media (prefers-color-scheme: dark) {
    .support-form__status {
      color: #7fd6be;
    }
  }
  .support-form.is-done .field,
  .support-form.is-done .support-form__consent,
  .support-form.is-done .cf-turnstile,
  .support-form.is-done .support-form__actions {
    display: none;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('.support-form');
  if (form) {
    const email = form.querySelector<HTMLInputElement>('#sp-email')!;
    const message = form.querySelector<HTMLTextAreaElement>('#sp-message')!;
    const consent = form.querySelector<HTMLInputElement>('input[name="privacy"]')!;
    const idField = form.querySelector<HTMLInputElement>('input[name="submission_id"]')!;
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const status = form.querySelector<HTMLParagraphElement>('#sp-status')!;
    const t = (k: string, fallback: string) => form.dataset[k] || fallback;
    let pending = false;

    const say = (m: string) => {
      status.textContent = m;
    };
    const newId = () => {
      idField.value =
        typeof crypto !== 'undefined' && 'randomUUID' in crypto
          ? crypto.randomUUID()
          : String(Date.now()) + '-' + Math.random().toString(16).slice(2);
    };

    // Stable id for retries (regenerated only after a successful send).
    newId();

    // Prefill version/build from the query string (?v=&b=).
    const q = new URLSearchParams(location.search);
    const v = q.get('v');
    const b = q.get('b');
    if (v) (form.querySelector<HTMLInputElement>('#sp-version')!).value = v.slice(0, 32);
    if (b) (form.querySelector<HTMLInputElement>('#sp-build')!).value = b.slice(0, 16);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (pending) return;

      email.setAttribute('aria-invalid', 'false');
      message.setAttribute('aria-invalid', 'false');
      if (!email.value || !email.checkValidity()) {
        email.setAttribute('aria-invalid', 'true');
        say(t('checkEmail', 'Check the email address and try again.'));
        email.focus();
        return;
      }
      if (message.value.trim().length < 10) {
        message.setAttribute('aria-invalid', 'true');
        say(t('tooShort', 'Write a few more words so we can help.'));
        message.focus();
        return;
      }
      if (!consent.checked) {
        say(t('needConsent', 'We need your consent to handle the request.'));
        consent.focus();
        return;
      }

      pending = true;
      button.disabled = true;
      say('…');
      try {
        const res = await fetch('/api/support', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(new FormData(form) as any).toString(),
        });
        if (!res.ok) throw new Error(String(res.status));
        form.classList.add('is-done');
        say(t('success', 'Thank you. We’ve received your message and will reply by email.'));
        status.focus?.();
      } catch {
        // Keep everything the user typed; allow a retry with the same id.
        say(t('fail', 'Nothing was lost. Try again whenever you like.'));
        button.disabled = false;
      } finally {
        pending = false;
      }
    });
  }
</script>
