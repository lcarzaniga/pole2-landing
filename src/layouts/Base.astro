---
import '../styles/global.css';
import {
  STRINGS,
  basePath,
  localeFromPath,
  localizedPath,
  DEFAULT_LOCALE,
} from '../i18n';
import LangSwitch from '../components/LangSwitch.astro';

interface Props {
  title?: string;
  description?: string;
}

// The locale is derived from the URL, so Italian pages need no extra prop and
// English pages under /en/ are detected automatically.
const locale = localeFromPath(Astro.url.pathname);
const s = STRINGS[locale];

const defaults = {
  it: {
    title: 'Pole² — Custodisci ciò che conta',
    description:
      'Pole² è una casa serena per le cose a cui tieni: ricevute, garanzie, manuali e ricordi, tutti insieme e al sicuro sul tuo dispositivo.',
  },
  en: {
    title: 'Pole² — Keep what matters',
    description:
      'Pole² is a calm home for the things you care about: receipts, warranties, manuals and memories, all together and safe on your device.',
  },
};
const {
  title = defaults[locale].title,
  description = defaults[locale].description,
} = Astro.props;

// SEO: self-referencing canonical + reciprocal hreflang. The logical path is
// shared between locales; pole2.app stays canonical for every URL.
const base = basePath(Astro.url.pathname);
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const itHref = new URL(localizedPath(base, 'it'), Astro.site).href;
const enHref = new URL(localizedPath(base, 'en'), Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const ogAlt =
  locale === 'it'
    ? 'Pole² — «So di averlo. Ma dov’è?»'
    : 'Pole² — “I know I have it. But where?”';
---

<!doctype html>
<html lang={s.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Reciprocal alternates: each locale's equivalent page, plus x-default. -->
    <link rel="alternate" hreflang="it" href={itHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={itHref} />
    <meta name="theme-color" content="#2e6b5e" />
    <meta name="color-scheme" content="light dark" />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload only the wordmark font (small, above-the-fold LCP). Inter loads
         via @font-face with font-display:swap, so body text never blocks. -->
    <link
      rel="preload"
      href="/fonts/WorkSans-Variable.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />

    <!-- Social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Pole²" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={s.ogLocale} />
    <meta
      property="og:locale:alternate"
      content={locale === 'it' ? 'en_US' : 'it_IT'}
    />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Pole²',
        url: Astro.site?.href,
        inLanguage: s.htmlLang,
        description,
      })}
    />

    <!-- No-flash: mark JS available before paint so scroll-reveal can hide,
         yet the page stays fully visible if JS never runs. -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>

    {
      /* First-visit language detection — client-side only, root page only. No
         server redirect, no loop (it only ever sends the Italian root to /en/,
         never the reverse), and a saved choice always wins. */
      locale === DEFAULT_LOCALE && base === '/' && (
        <script
          is:inline
          set:html={`(function(){try{var s=localStorage.getItem('pole2-lang');if(s==='it'||s==='en')return;var ls=navigator.languages||[navigator.language||''];var it=ls.some(function(l){return (l||'').toLowerCase().indexOf('it')===0;});if(!it)location.replace('/en/');}catch(e){}})();`}
        />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#contenuto">{s.skip}</a>
    <div class="topbar">
      <div class="wrap topbar__inner">
        <LangSwitch locale={locale} base={base} />
      </div>
    </div>
    <slot />

    <script>
      // Gentle scroll-reveal — reveals sections once, respects Reduce Motion,
      // and is a no-op enhancement (content is visible without it).
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const items = Array.from(document.querySelectorAll<HTMLElement>('.reveal'));
      if (reduce || !('IntersectionObserver' in window)) {
        items.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                obs.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -12% 0px', threshold: 0.08 }
        );
        items.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>

<style>
  .topbar {
    border-bottom: 1px solid var(--hairline);
  }
  .topbar__inner {
    display: flex;
    justify-content: flex-end;
    padding-block: 0.6rem;
  }
</style>
