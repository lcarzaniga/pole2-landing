# Cloudflare Pages headers (https://developers.cloudflare.com/pages/configuration/headers/)

# Long-lived, immutable caching for fingerprinted assets and self-hosted fonts.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Calm, sensible security defaults for every response.
#
# CSP: default self. The ONLY external origin permitted is Cloudflare Turnstile
# (script + iframe + its verification XHR). 'unsafe-inline' covers the site's own
# small inline enhancement script and Astro's auto-inlined styles — it does not
# widen anything for Turnstile. Form posts are same-origin (connect/form 'self').
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: interest-cohort=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; connect-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com
